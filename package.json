{
  "private": true,
  "scripts": {
    "dev": "pnpm -F playground dev",
    "build:wasm": "cd packages/wasm && wasm-pack build --target web && cd ../.. && node packages/core/scripts/setup-wasm.mjs",
    "build": "pnpm -F sweet-subtitle build",
    "test": "pnpm -F sweet-subtitle test",
    "publish:core": "pnpm -F sweet-subtitle publish --access public --no-git-checks",
    "release:dry": "pnpm -F sweet-subtitle publish --access public --dry-run --no-git-checks",
    "release": "pnpm run publish:core"
  },
  "devDependencies": {
    "typescript": "~5.8.0"
  },
  "engines": {
    "node": ">=18"
  }
}
