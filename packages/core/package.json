{
  "name": "sweet-subtitle",
  "version": "0.1.2",
  "description": "Browser subtitle library with full ASS/SSA rendering support",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],  "scripts": {
    "dev": "tsup --watch",
    "prebuild": "node scripts/setup-wasm.mjs",
    "build": "tsup",
    "prepublishOnly": "cp ../../README.md . && pnpm -w build:wasm && pnpm build",
    "postpublish": "rm -f README.md",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "subtitle",
    "srt",
    "vtt",
    "ass",
    "ssa",
    "webvtt",
    "video",
    "caption"
  ],
  "license": "MIT",
  "devDependencies": {
    "tsup": "^8.4.0",
    "typescript": "~5.8.0",
    "vitest": "^3.1.0"
  }
}
