{
  "name": "sweet-subtitle",
  "version": "1.0.0",
  "description": "Subtitle renderer and parser for web video: ASS/SSA, SRT, WebVTT, SBV, TTML/DFXP with React/Vue/Angular adapters and WASM effects",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js",
      "require": "./dist/react.cjs"
    },
    "./vue": {
      "types": "./dist/vue.d.ts",
      "import": "./dist/vue.js",
      "require": "./dist/vue.cjs"
    },
    "./angular": {
      "types": "./dist/angular.d.ts",
      "import": "./dist/angular.js",
      "require": "./dist/angular.cjs"
    }
  },
  "files": [
    "dist"
  ],  "scripts": {
    "dev": "tsup --watch",
    "prebuild": "node scripts/setup-wasm.mjs",
    "build": "tsup",
    "prepublishOnly": "cp ../../README.md . && pnpm -w build:wasm && pnpm build",
    "postpublish": "rm -f README.md",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "subtitle",
    "subtitles",
    "subtitle-renderer",
    "subtitle-parser",
    "video-subtitle",
    "video-captions",
    "srt",
    "vtt",
    "webvtt",
    "ass",
    "ssa",
    "ttml",
    "dfxp",
    "sbv",
    "captions",
    "react",
    "vue",
    "angular",
    "wasm",
    "video",
    "caption"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/leuvi/sweet-subtitle.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/leuvi/sweet-subtitle",
  "bugs": {
    "url": "https://github.com/leuvi/sweet-subtitle/issues"
  },
  "devDependencies": {
    "@angular/core": "^20.0.0",
    "@types/react": "^19.2.2",
    "tsup": "^8.4.0",
    "typescript": "~5.8.0",
    "vitest": "^3.1.0",
    "vue": "^3.5.13"
  },
  "peerDependencies": {
    "@angular/core": ">=16.0.0",
    "react": ">=18",
    "vue": ">=3.3.0"
  },
  "peerDependenciesMeta": {
    "@angular/core": {
      "optional": true
    },
    "react": {
      "optional": true
    },
    "vue": {
      "optional": true
    }
  }
}
